<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="5dp">

        <!-- GodMode Module -->
        <LinearLayout
            android:id="@+id/module_godmode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fuction_drawable"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_clone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:text="GodMode"
                    android:textColor="#E2E2E2"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/info_godmode"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginRight="5dp"
                    android:src="@drawable/applovin_ic_privacy_icon_layered_list" />

                <Switch
                    android:id="@+id/switch_godmode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:scaleX="0.9"
                    android:scaleY="0.9"
                    android:textSize="12sp"
                    android:thumbTint="@color/thumb_tint"
                    android:thumbTintMode="src_in"
                    android:trackTint="#2A2E2E" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/setting_godmode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/linear_setting_godmode_granny"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/textView7"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/roboto_medium_numbers"
                        android:text="Granny Mode"
                        android:textColor="#E2E2E2"
                        android:textSize="10sp" />

                    <Switch
                        android:id="@+id/switch_granny_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:thumbTint="@color/thumb_tint"
                        android:trackTint="#2A2E2E" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linear_setting_godmode_momspider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/textView8"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/roboto_medium_numbers"
                        android:text="MomSpider Mode"
                        android:textColor="#E2E2E2"
                        android:textSize="10sp" />

                    <Switch
                        android:id="@+id/switch_momspider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:thumbTint="@color/thumb_tint"
                        android:trackTint="#2A2E2E" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Granny Clone Module -->
        <LinearLayout
            android:id="@+id/module_clone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/fuction_drawable"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_godmode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:text="Granny Clone"
                    android:textColor="#E2E2E2"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/granny_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/drawable_round_left"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="+"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/count_granny"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#B2DFDB"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="0"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/granny_minus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="13dp"
                    android:background="@drawable/drawable_round_right"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="-"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- MomSpider Clone Module -->
        <LinearLayout
            android:id="@+id/module_clone_spider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/fuction_drawable"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_spider_clone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:text="MomSpider Clone"
                    android:textColor="#E2E2E2"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/spider_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/drawable_round_left"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="+"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/count_spider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#B2DFDB"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="0"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/spider_minus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="13dp"
                    android:background="@drawable/drawable_round_right"
                    android:fontFamily="@font/roboto_medium_numbers"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:text="-"
                    android:textColor="#272A2A"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>