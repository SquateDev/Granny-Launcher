        <item name="android:textSize">@dimen/notification_action_text_size</item>
        <item name="android:textColor">@color/androidx_core_secondary_text_default_material_light</item>
    </style>
    <style name="com.applovin.creative.CreativeDebuggerActivity.ActionBar" parent="@android:style/Widget.Material.Light.ActionBar">
        <item name="android:background">@color/applovin_sdk_brand_color</item>
        <item name="android:height">@dimen/applovin_sdk_actionBarHeight</item>
        <item name="android:displayOptions">showTitle</item>
        <item name="android:titleTextStyle">@style/com.applovin.creative.CreativeDebuggerActivity.ActionBar.TitleTextStyle</item>
        <item name="android:actionBarItemBackground">@style/com.applovin.creative.CreativeDebuggerActivity.ActionBar.TitleTextStyle</item>
    </style>
    <style name="com.applovin.creative.CreativeDebuggerActivity.ActionBar.TitleTextStyle" parent="@android:style/TextAppearance.Material.Widget.ActionBar.Title">
        <item name="android:textColor">@color/applovin_sdk_textColorPrimary</item>
    </style>
    <style name="com.applovin.creative.CreativeDebuggerActivity.Theme" parent="@android:style/Theme.Material.Light">
        <item name="android:actionBarStyle">@style/com.applovin.mediation.MaxDebuggerActivity.ActionBar</item>
        <item name="android:actionMenuTextColor">@color/applovin_sdk_textColorPrimary</item>
